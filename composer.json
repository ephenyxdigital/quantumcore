        "phpmailer/phpmailer": "^7",
        "pear/archive_tar": "^1",
        "ephenyxdigital/digitalspreadsheet": "^4",
        "rosell-dk/webp-convert": "^2",
        "rosell-dk/webp-convert-cloud-service": "^2",
        "rosell-dk/dom-util-for-webp": "^0.7",
        "ephenyxdigital/einvoice": "^2",
        "ephenyxdigital/devicedetect": "^1",
