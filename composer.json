    "authors": [
        {
            "name": "Jeff Hunger",
            "homepage": "https://ephenyx.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "defuse/php-encryption": "^2",
        "nicolab/php-ftp-client": "^2",
        "phpseclib/phpseclib": "~3.0",
